# Shopkeeper Configuration
# Backend server settings
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/shopkeeper

# Session Configuration
SESSION_TIMEOUT=3600000  # 1 hour in milliseconds

# Email Notifications (Optional)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-password
# ADMIN_EMAIL=admin@business.com

# ============ BLOCKCHAIN CONFIG ============
# Ganache Local Blockchain
# Use the RPC shown in your Ganache app (commonly 7545 or 8545)
GANACHE_RPC_URL=http://127.0.0.1:7545

# Smart Contract Address (after deployment)
CONTRACT_ADDRESS=0x...

# Owner's Private Key (from Ganache account)
PRIVATE_KEY=0x...

# ============ SECURITY NOTES ============
# 1. Never commit real private keys to version control
# 2. Use environment-specific .env files
# 3. Rotate private keys regularly in production
# 4. Use hardware security modules (HSM) for production keys

# ============ GANACHE SETUP ============
# 1. Install Ganache: https://trufflesuite.com/ganache/
# 2. Start Ganache (use the RPC URL shown in Ganache)
# 3. Copy private key from any account in Ganache
# 4. Set PRIVATE_KEY above
# 5. Deploy ShopkeeperAnchor.sol contract
# 6. Set CONTRACT_ADDRESS to deployed contract address